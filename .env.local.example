# ---------------------------------------------------------------------------
# PixelPop Digi — environment variables
# Copy this file to `.env.local` and fill in the values. Never commit .env.local.
# ---------------------------------------------------------------------------

# The Google Apps Script Web App endpoint that receives contact form submissions.
# This is kept SERVER-SIDE only (no NEXT_PUBLIC_ prefix), so it is never exposed
# to the browser. The form POSTs to /api/contact, which forwards securely here.
#
# This file is a COMMITTED TEMPLATE — do NOT put the real URL here.
# Set the real value in:
#   - local dev:   .env.local  (git-ignored)
#   - production:  Netlify → Site settings → Environment variables
CONTACT_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXX/exec

# Optional: shared secret you can validate inside the Apps Script doPost(e)
# to reject requests that do not originate from this site.
CONTACT_WEBHOOK_TOKEN=

# Public site URL (used for canonical + Open Graph metadata).
NEXT_PUBLIC_SITE_URL=https://www.pixelpopdigi.com
